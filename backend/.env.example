## Backend Environment Variables
# Copy this file to .env and fill in the values from Supabase & Upstash

# Supabase Configuration
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=eyJxxx...

# Upstash Redis Configuration
UPSTASH_URL=https://xxxxx.upstash.io
UPSTASH_TOKEN=xxxxx

# Server Configuration
PORT=3000
NODE_ENV=development

# Game Configuration
TICK_RATE=15
MAX_CONCURRENT_MATCHES=50

# Logging
LOG_LEVEL=debug

# Keep-Alive (Render free tier)
KEEP_ALIVE_INTERVAL=840000
